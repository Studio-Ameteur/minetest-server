# ===========================================
# .gitignore — файлы которые НЕ попадают в репозиторий
# ===========================================

# Секреты и конфигурация окружения
.env
.env.local
.env.production

# Логи сервера
*.log
logs/

# Временные файлы
*.tmp
*.cache

# Системные файлы
.DS_Store
Thumbs.db

# Данные мира (генерируются на сервере)
worlds/

# Скомпилированные файлы
*.o
*.a
*.so
build/
