# ===========================================
# .env.example — шаблон переменных окружения
# Скопируйте в .env и заполните реальными значениями
# Файл .env никогда не попадает в репозиторий
# ===========================================

# --- Сервер ---
SERVER_IP=your-server-ip
SERVER_PORT=30000

# --- Laravel API ---
LARAVEL_API_URL=https://your-domain.com/api
LARAVEL_SERVER_TOKEN=your-secret-token-here

# --- База данных (если нужна) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=minetest
DB_USER=your-db-user
DB_PASSWORD=your-db-password
